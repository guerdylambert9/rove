# Supabase — create a project at https://supabase.com
# Then run supabase/migrations/001_initial_schema.sql in the SQL editor.
#
# Where to find these values (new Supabase dashboard):
#   Project URL  → Integrations → Data API → copy the API URL and remove "/rest/v1/"
#                  e.g. https://xxxxx.supabase.co/rest/v1/  →  https://xxxxx.supabase.co
#   API key      → Settings → API Keys → Publishable key (sb_publishable_...)
#                  OR the "Legacy anon, service_role API keys" tab → anon public (eyJ...)
#
# Put this file at the project ROOT (not src/). Vite does not read src/.env.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-or-anon-key
